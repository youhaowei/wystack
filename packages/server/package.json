{
  "name": "@wystack/server",
  "version": "0.0.1",
  "description": "Reactive data engine with function registry, subscription management, and multi-transport support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./bun": {
      "import": "./dist/serve-bun.js",
      "types": "./dist/serve-bun.d.ts"
    },
    "./node": {
      "import": "./dist/serve-node.js",
      "types": "./dist/serve-node.d.ts"
    },
    "./routes": {
      "import": "./dist/routes.js",
      "types": "./dist/routes.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@hono/node-ws": "^1.3.0",
    "@wystack/db": "workspace:*",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "drizzle-orm": "^0.45.1",
    "typescript": "^5.8.3"
  }
}
