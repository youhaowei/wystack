{
  "name": "@wystack/server",
  "version": "0.0.1",
  "description": "Reactive data engine with function registry, subscription management, and multi-transport support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./bun": {
      "types": "./dist/serve-bun.d.ts",
      "bun": "./src/serve-bun.ts",
      "import": "./dist/serve-bun.js"
    },
    "./node": {
      "types": "./dist/serve-node.d.ts",
      "bun": "./src/serve-node.ts",
      "import": "./dist/serve-node.js"
    },
    "./electron": {
      "types": "./dist/electron.d.ts",
      "bun": "./src/electron.ts",
      "import": "./dist/electron.js"
    },
    "./routes": {
      "types": "./dist/routes.d.ts",
      "bun": "./src/routes.ts",
      "import": "./dist/routes.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test src"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@hono/node-ws": "^1.3.0",
    "@wystack/db": "workspace:*",
    "@wystack/transport": "workspace:*",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "drizzle-orm": "^0.45.1",
    "typescript": "^5.8.3"
  }
}
