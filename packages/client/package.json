{
  "name": "@wystack/client",
  "version": "0.0.1",
  "description": "React hooks and reactive client for WyStack",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./electron": {
      "types": "./dist/transport/electron.d.ts",
      "bun": "./src/transport/electron.ts",
      "import": "./dist/transport/electron.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test src"
  },
  "dependencies": {
    "@wystack/transport": "workspace:*"
  },
  "devDependencies": {
    "@electric-sql/pglite": ">=0.3.0",
    "@happy-dom/global-registrator": "20.10.1",
    "@tanstack/react-query": "^5.90.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "@wystack/db": "workspace:*",
    "@wystack/server": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "happy-dom": "^20.10.1",
    "react": "^19.0.0",
    "react-dom": "19.2.4",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=19.0.0"
  }
}
