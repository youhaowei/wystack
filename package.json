{
  "name": "wystack",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "oxlint packages/",
    "format": "bunx oxfmt packages/*/src",
    "format:check": "bunx oxfmt --check packages/*/src",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "check": "oxlint packages/ && bunx oxfmt --check packages/*/src && turbo typecheck test",
    "clean": "turbo clean",
    "clawpatch": "scripts/clawpatch.sh",
    "clawpatch:map": "scripts/clawpatch.sh map --source heuristic --json",
    "clawpatch:review": "scripts/clawpatch.sh map --source heuristic --json && scripts/clawpatch.sh review --since origin/main --json --no-input"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@types/bun": "^1.3.10",
    "postgres": "^3.4.8",
    "turbo": "^2.9.3",
    "typescript": "^5.8.3"
  }
}
