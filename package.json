{
  "name": "wystack",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": ["packages/*", "apps/*", "apps/workhub/packages/*", "apps/dashframe/packages/*"],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "oxlint packages/ apps/",
    "format": "oxfmt packages/ apps/",
    "format:check": "oxfmt --check packages/ apps/",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "check": "oxlint packages/ apps/ && oxfmt --check packages/ apps/ && turbo typecheck test",
    "storybook": "turbo storybook",
    "clean": "turbo clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@electric-sql/pglite": "^0.3.16",
    "@types/bun": "^1.3.10",
    "postgres": "^3.4.8",
    "turbo": "^2.9.3",
    "typescript": "^5.8.3"
  }
}
